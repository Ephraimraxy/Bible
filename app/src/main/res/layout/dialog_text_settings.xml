<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Font Size"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:textStyle="bold"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <SeekBar
            android:id="@+id/sbFontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/tvFontSizeVal"
            android:layout_centerVertical="true"/>

        <TextView
            android:id="@+id/tvFontSizeVal"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="end"
            android:text="18sp"
            android:textColor="@color/royal_blue"
            android:textStyle="bold"/>
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Line Spacing"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:textStyle="bold"
        android:layout_marginTop="24dp"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <SeekBar
            android:id="@+id/sbLineSpacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/tvLineSpacingVal"
            android:layout_centerVertical="true"/>

        <TextView
            android:id="@+id/tvLineSpacingVal"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="end"
            android:text="1.6"
            android:textColor="@color/royal_blue"
            android:textStyle="bold"/>
    </RelativeLayout>
</LinearLayout>
